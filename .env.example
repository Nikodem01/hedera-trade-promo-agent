# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Hedera testnet account — get one at https://portal.hedera.com
# ECDSA account (portal default). The private key is the HEX-encoded ECDSA key (0x...).
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=0x...
HEDERA_NETWORK=testnet

# LLM provider. "google" uses Gemini (free tier) for dev/verification; unset or
# "anthropic" uses the production thesis (Sonnet 4.6 + Opus 4.7). Per-role model
# ids are overridable via ORCHESTRATOR_MODEL / VISION_MODEL.
LLM_PROVIDER=anthropic
# ORCHESTRATOR_MODEL=gemini-2.5-flash
# VISION_MODEL=gemini-2.5-flash

# Anthropic API key — https://console.anthropic.com (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key — https://aistudio.google.com/apikey (used when LLM_PROVIDER=google)
GOOGLE_GENERATIVE_AI_API_KEY=

# Clean proof-only HCS audit topic for trade-promo claims. Public messages must contain
# only cryptographic commitments/fingerprints + timestamps, never business data.
HCS_TOPIC_ID=
# Optional: verbose Agent Kit hook audit. Leave unset for public demos so HCS stays
# proof-only; set to 1 only for private debugging.
ENABLE_VERBOSE_HCS_TOOL_AUDIT=

# Populated after the agent runs `create_fungible_token` once (the "PromoProof Receipt" token)
HTS_RECEIPT_TOKEN_ID=

# Optional: enable NFT attestation receipts. Set to the "PromoProof Attestation"
# NFT collection id printed by scripts/setup-hedera.mjs. When set, proof-only agent
# attestations/settlement receipts can mint serial-numbered NFTs whose metadata/URI is
# the adjudication commitment only.
HTS_RECEIPT_NFT_TOKEN_ID=

# The retailer's settlement wallet (the only valid payout recipient). Defaults to 0.0.98.
RETAILER_WALLET_ID=

# Optional: global per-settlement safety ceiling in HBAR (default 50).
SETTLEMENT_HARD_CAP_HBAR=

# --- Enterprise-grade posture ---
# Encrypts the at-rest dossier store (AES-256-GCM). REQUIRED in production; if unset,
# dossiers are stored in plaintext (local dev only). Use a long, high-entropy secret.
DOSSIER_ENC_KEY=
# Keyed (HMAC) image-fingerprint secret for cross-claim proof-reuse detection. Set a
# stable high-entropy value in production (a demo default is used if unset).
IMAGE_FP_KEY=
# Model-risk safety gate: a FINAL decision below this confidence (or one the independent
# reviewer flags for escalation) is auto-held for a human. Default 0.5.
CONFIDENCE_FLOOR=

# --- Public hosting (see docs/DEPLOY.md) ---
# Set to 1 on a public deployment: anonymous visitors get the unified cached-anchor +
# rate-limited live sandbox; privileged back-office actions require the operator token.
# Unset (local/operator-only host) = everything allowed.
PUBLIC_READONLY=
# Shared operator token that unlocks live mode + gated actions when PUBLIC_READONLY=1.
# Use a long, high-entropy value; sent as the `x-operator-token` header / `op_token` cookie.
OPERATOR_ACCESS_TOKEN=
